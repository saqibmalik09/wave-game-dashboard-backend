{
  "name": "wave-games",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "reset:master": "npx prisma migrate reset --schema=./prisma/master/schema.prisma --force",
    "reset:tenant": "npx prisma migrate reset --schema=./prisma/tenant/schema.prisma --force",
    "migrate:master": "prisma migrate dev --schema=prisma/master/schema.prisma",
    "migrate:tenant": "prisma migrate dev --schema=prisma/tenant/schema.prisma",
    "pm2": "pm2 start dist/main.js --name wave-game-backend",
    "stop:both": "pm2 stop wave-game-front  && pm2 stop wave-game-backend",
    "restart:both": "pm2 restart wave-game-backend &&pm2 restart wave-game-front",
    "migrate:sync:master": "npx prisma db push --schema=prisma/master/schema.prisma",
    "migrate:sync:tenant": "npx prisma db push --schema=prisma/tenant/schema.prisma",
    "migrate:create:master": "npx prisma migrate dev --create-only --schema=prisma/master/schema.prisma",
    "generate:master": "npx prisma generate --schema=prisma/master/schema.prisma",
    "generate:tenant": "npx prisma generate --schema=prisma/tenant/schema.prisma",
    "generate:all": "npm run generate:master && npm run generate:tenant",
    "migrate:rbac": "ts-node database/run-migrations.ts",
    "rbac:setup": "npm run migrate:rbac"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.1.6",
    "axios": "^1.13.4",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ejs": "^3.1.10",
    "ioredis": "^5.8.2",
    "js-cookie": "^3.0.5",
    "jwt-decode": "^4.0.0",
    "mysql2": "^3.15.1",
    "opossum": "^9.0.0",
    "p-queue": "^9.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@prisma/client": "^6.16.2",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.16.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
